# The app already defaults to the deployed Tencent Cloud backend (hardcoded in
# src/config.ts), so you normally don't need this file at all.
#
# Copy to `.env` (gitignored) only if you want to override that default — e.g.
# to point the app at your Mac for local backend development instead:
#
#   EXPO_PUBLIC_BACKEND_HTTP_URL=http://<your-mac-lan-ip>:8000
#   EXPO_PUBLIC_BACKEND_WS_URL=ws://<your-mac-lan-ip>:8000/v1/realtime/session
#
# You can also just edit the "Backend HTTP URL" / "Backend WebSocket URL"
# fields directly in the running app — both always take priority over whatever
# the app launched with.
EXPO_PUBLIC_BACKEND_HTTP_URL=
EXPO_PUBLIC_BACKEND_WS_URL=
