# Copy this file to backend/.env and fill in real values.
# .env is gitignored — never commit real API keys.

ENV=dev
JWT_SECRET=change-me

ASR_PROVIDER=deepgram
TTS_PROVIDER=elevenlabs
LLM_PROVIDER=deepseek

# DeepSeek (OpenAI-compatible). Docs: https://api-docs.deepseek.com/
# Leave the placeholder value to keep the app running with echo-style fallback replies.
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Deepgram (prerecorded transcription). Docs: https://developers.deepgram.com/docs/pre-recorded-audio
# Leave the placeholder value to keep the app running with a labeled placeholder transcript.
DEEPGRAM_API_KEY=REPLACE_WITH_DEEPGRAM_API_KEY
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_MODEL=nova-3

# Alibaba Cloud Intelligent Speech Interaction (NLS), one-sentence recognition.
# Docs: https://help.aliyun.com/zh/isi/developer-reference/restful-api-2
# Set ASR_PROVIDER=alibaba to use this instead of Deepgram.
# ALIBABA_ACCESS_KEY_ID / ALIBABA_ACCESS_KEY_SECRET: RAM AccessKey pair (used to
# auto-fetch a short-lived X-NLS-Token — no manual token refresh needed).
# ALIBABA_APP_KEY: created in the Intelligent Speech Interaction console project.
ALIBABA_ACCESS_KEY_ID=REPLACE_WITH_ALIBABA_ACCESS_KEY_ID
ALIBABA_ACCESS_KEY_SECRET=REPLACE_WITH_ALIBABA_ACCESS_KEY_SECRET
ALIBABA_APP_KEY=REPLACE_WITH_ALIBABA_APP_KEY
ALIBABA_REGION=cn-shanghai
ALIBABA_ASR_BASE_URL=https://nls-gateway-cn-shanghai.aliyuncs.com/stream/v1/asr
ALIBABA_TOKEN_BASE_URL=https://nls-meta.cn-shanghai.aliyuncs.com/
ALIBABA_SAMPLE_RATE=16000
